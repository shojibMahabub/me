---
// Decap CMS admin entry point.
//
// Why this is an Astro page (not just public/admin/index.html):
//   Astro's dev server serves everything under public/ as-is, but it does NOT
//   resolve directory indexes. So public/admin/index.html is reachable in dev
//   at /admin/index.html but NOT at /admin/ (which 404s). Making this a real
//   Astro route fixes that asymmetry between dev and prod.
//
// Decap still loads its config from /admin/config.yml, which is served
// statically from public/admin/config.yml.
export const prerender = true;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Content manager · Mahabub Elahi</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="cms-config-url" type="text/yaml" href="/admin/config.yml" />
    <link rel="stylesheet" href="/admin/preview.css" />
</head>
<body>
    <script is:inline>
        // Decap uses `backend: git-gateway` for production and the local
        // decap-server proxy for dev (because `local_backend: true` is set in
        // config.yml). The Netlify Identity widget only has a job in
        // production: it provides the login flow for git-gateway. On
        // localhost it auto-inits, realises there's no Identity service and
        // throws "Unable to access identity settings" — which looks like a
        // real failure to editors. Skip it entirely on localhost.
        (function () {
            var h = window.location.hostname;
            var isLocal =
                h === 'localhost' ||
                h === '127.0.0.1' ||
                h === '0.0.0.0' ||
                h === '' ||
                h.endsWith('.local');
            if (isLocal) return;
            var s = document.createElement('script');
            s.src = 'https://identity.netlify.com/v1/netlify-identity-widget.js';
            s.async = false;
            document.head.appendChild(s);
        })();
    </script>
    <script is:inline src="https://unpkg.com/decap-cms@^3.3.0/dist/decap-cms.js"></script>
    <script is:inline src="/admin/preview.js"></script>
    <script is:inline>
        // Pull the user back to /admin/ after Netlify Identity finishes login
        // (it redirects them to the homepage with a hash token). This only
        // runs in production where the widget was actually loaded above.
        if (window.netlifyIdentity) {
            window.netlifyIdentity.on('init', function (user) {
                if (!user) {
                    window.netlifyIdentity.on('login', function () {
                        document.location.href = '/admin/';
                    });
                }
            });
        }
    </script>
</body>
</html>
