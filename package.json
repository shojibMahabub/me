{
  "name": "mahabub-portfolio",
  "version": "0.1.0",
  "description": "Story-driven portfolio, CMS-backed via Decap, deployed on Netlify.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "cms": "decap-server",
    "dev:cms": "concurrently -n astro,cms -c cyan,magenta \"npm:dev\" \"npm:cms\"",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^4.0.3",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.2.1",
    "astro": "^5.1.1",
    "bootstrap": "^5.3.3",
    "sass": "^1.83.0",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@popperjs/core": "^2.11.8",
    "@types/bootstrap": "^5.2.10",
    "concurrently": "^9.2.1",
    "decap-server": "^3.7.0"
  }
}
